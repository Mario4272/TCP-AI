{
  "version": "0.3",
  "markers": {
    "?": {
      "type": "modality",
      "meaning": "curious / open-ended"
    },
    "!": {
      "type": "modality",
      "meaning": "direct / blunt"
    },
    "~": {
      "type": "modality",
      "meaning": "casual / relaxed"
    },
    "=": {
      "type": "modality",
      "meaning": "neutral / objective"
    },
    ">": {
      "type": "modality",
      "meaning": "authoritative / formal"
    },
    "+": {
      "type": "modality",
      "meaning": "enthusiastic / collaborative"
    },
    "*": {
      "type": "modality",
      "meaning": "urgent / critical"
    },
    ".b": {
      "type": "response_shape",
      "meaning": "bulleted list"
    },
    ".m": {
      "type": "response_shape",
      "meaning": "markdown formatted"
    },
    ".l": {
      "type": "response_shape",
      "meaning": "links/references"
    },
    ".opt": {
      "type": "register",
      "meaning": "provide options"
    },
    ".rec": {
      "type": "register",
      "meaning": "provide recommendations"
    },
    ".why": {
      "type": "register",
      "meaning": "explain reasoning"
    },
    ".ans": {
      "type": "register",
      "meaning": "direct answer only"
    },
    ".blunt": {
      "type": "register",
      "meaning": "no fluff / direct"
    },
    ".soft": {
      "type": "register",
      "meaning": "gentle / supportive"
    }
  },
  "categories": {
    "general_qna": {
      "description": "General factual or reference-style questions"
    },
    "brief_explanation": {
      "description": "Short, concise explanations or definitions"
    },
    "technical_explanation": {
      "description": "Deep dives into technical or scientific topics"
    },
    "coding_request": {
      "description": "Requests for code generation or software architecture"
    },
    "debugging_request": {
      "description": "Assistance with fixing errors or optimizing code"
    },
    "writing_editing": {
      "description": "Creative or formal writing, editing, and proofreading"
    },
    "brainstorming": {
      "description": "Idea generation and creative exploration"
    },
    "architecture": {
      "description": "Systems design and high-level conceptual planning"
    },
    "decision_recommendation": {
      "description": "Requests for help making choices or selecting options"
    },
    "skeptical_review": {
      "description": "Critical analysis or steel-manning of arguments"
    },
    "personal_important": {
      "description": "Sensitive, private, or high-stakes personal context"
    },
    "structured_data_wrapper": {
      "description": "Handling and transforming data payloads (JSON, CSV, etc.)"
    }
  },
  "corpus_schema": {
    "required_fields": [
      "id",
      "category",
      "natural_prompt",
      "tcp_prompt",
      "markers",
      "expected_response_shape",
      "risk_notes",
      "compression_notes"
    ],
    "optional_fields": [
      "metadata"
    ]
  },
  "syntax_notes": {
    "parentheses": "Allowed for grouping/context; not a v0.3 marker."
  }
}
